# Supabase Database - Get this from: Project Settings → Database → Connection string (URI)
DATABASE_URL=postgresql://postgres.[project-ref]:[YOUR-PASSWORD]@aws-0-[region].pooler.supabase.com:5432/postgres

# Supabase Auth - Get from: Project Settings → API
# URL: https://[project-ref].supabase.co
SUPABASE_URL=https://[project-ref].supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Frontend (Vercel): Add VITE_ prefixed vars
# VITE_SUPABASE_URL=https://[project-ref].supabase.co
# VITE_SUPABASE_ANON_KEY=your-anon-key

# === Split deployment (Vercel + Railway) ===
# On Railway: Your Vercel frontend URL (e.g. https://yourapp.vercel.app)
# FRONTEND_URL=https://yourapp.vercel.app

# On Vercel: Your Railway backend URL (e.g. https://yourapp.up.railway.app)
# VITE_API_URL=https://yourapp.up.railway.app

# === Optional ===
# PORT=5000
# SESSION_SECRET=your-session-secret

# Permanent premium emails (comma-separated). These users get full access without paying.
# PREMIUM_EMAILS=mangel3457@gmail.com,other@example.com

# === OpenAI / AI Parsing (Replit or direct) ===
# AI_INTEGRATIONS_OPENAI_API_KEY=sk-...
# AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.openai.com/v1
